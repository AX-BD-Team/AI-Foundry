# AI Foundry — Environment Variables Template
# Copy to .dev.vars (per service) or set via: printf 'value' | wrangler secret put SECRET_NAME
# Never commit actual values. See CLAUDE.md "Inter-Service Communication" section.

# --- Required (all services) ---
INTERNAL_API_SECRET=           # Shared secret for inter-service X-Internal-Secret header

# --- LLM Providers (svc-llm-router) ---
ANTHROPIC_API_KEY=             # Claude API key (Tier 1/2)
OPENAI_API_KEY=                # OpenAI API key (fallback)
GOOGLE_API_KEY=                # Google AI API key (fallback)
CF_AI_GATEWAY_TOKEN=           # Cloudflare AI Gateway token

# --- Document Parsing (svc-ingestion) ---
UNSTRUCTURED_API_KEY=          # Unstructured.io API key

# --- Graph DB (svc-extraction, svc-ontology) ---
NEO4J_URI=                     # Neo4j Aura connection URI
NEO4J_USER=                    # Neo4j username
NEO4J_PASSWORD=                # Neo4j password

# --- Cloudflare (deployment only, not in .dev.vars) ---
# CLOUDFLARE_API_TOKEN=        # Used for wrangler deploy, not stored in code
